    class Solution {
    public int[][] adjToMat(ArrayList<ArrayList<Integer>> adj) {
        int n = adj.size();
        int[][] matrix = new int[n][n];
        for(int i = 0; i < n; i++) {
            for(int j : adj.get(i)) {
                matrix[i][j] = 1;
            }
        }
        return matrix;
    }
}